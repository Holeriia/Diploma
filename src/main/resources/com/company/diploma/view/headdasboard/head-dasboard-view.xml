<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://headDasboardView.title">
    <data>
        <collection id="workspacesDc"
                    class="com.company.diploma.entity.Workspace">
            <fetchPlan extends="_base"/>
            <loader id="workspacesDl">
                <query>
                    <![CDATA[select e from Workspace e]]>
                </query>
            </loader>
        </collection>
        <collection id="tasksDc"
                    class="io.jmix.bpm.entity.TaskData">
            <loader id="tasksDl"/>
        </collection>
        <collection id="assignmentsDc"
                    class="com.company.diploma.entity.Assignment">
            <fetchPlan extends="_base">
                <property name="mentor" fetchPlan="_base">
                </property>
                <property name="mentee" fetchPlan="_base">
                </property>
                <property name="topic" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="assignmentsDl">
                <query>
                    <![CDATA[select e from Assignment e where e.workspace = :workspace]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout expand="tabSheet">
        <hbox id="topPanel" spacing="true" alignItems="END" classNames="pb-m">
            <entityComboBox id="workspaceField"
                            label="Выбор пространства"
                            metaClass="Workspace"
                            itemsContainer="workspacesDc"
                            width="300px"/>
            <button id="applyBtn"
                    text="Применить"
                    themeNames="primary"/>
        </hbox>

        <tabSheet id="tabSheet" width="100%">
            <tab id="tasksTab" label="Входящие">
                <vbox>
                    <h3 text="Мои задачи"/>
                    <dataGrid id="tasksDataGrid"
                              width="100%"
                              minHeight="15em"
                              dataContainer="tasksDc">
                        <columns>
                            <column property="name" header="Задача"/>
                            <column property="createTime" header="Получена" autoWidth="true"/>
                        </columns>
                        <actions>
                            <!-- действие для открытия формы задачи -->
                            <action id="openTaskForm" type="list_edit"/>
                        </actions>
                    </dataGrid>
                </vbox>
            </tab>
            <tab id="personalDataTab" label="Личные данные">
                <vbox padding="true" spacing="true" id="personalDataBox">
                    <hbox id="personalDataToolbar" spacing="true">
                        <button id="exportReportBtn"
                                text="Выгрузить отчет"
                                icon="DOWNLOAD"
                                themeNames="success"/>
                    </hbox>
                    <vbox id="studentsTablesContainer" width="100%" spacing="true"/>
                </vbox>
            </tab>
            <tab id="statisticsTab" label="Статистика">
                <vbox id="statisticsBox" padding="true" spacing="true">
                    <h3 text="Распределение студентов по преподавателям"/>
                    <button id="distributeBtn" text="Распределить оставшихся" icon="USERS"/>
                    <vbox id="statisticsTableContainer" width="100%"/>
                </vbox>
            </tab>
            <tab id="assignmentsTab" label="Назначения">
                <vbox padding="true" spacing="true">
                    <h3 text="Список назначений в пространстве"/>
                    <button id="exportWordReportBtn"
                            text="Выгрузить приказ (Word)"
                            icon="FILE"
                            themeNames="primary"/>
                    <dataGrid id="assignmentsDataGrid"
                              width="100%"
                              minHeight="20em"
                              dataContainer="assignmentsDc"
                              columnReorderingAllowed="true">
                        <columns>
                            <column property="mentor" header="Преподаватель"/>
                            <column property="mentee" header="Студент"/>
                            <column property="topic" header="Тема"/>
                            <column property="status" header="Статус"/>
                        </columns>
                    </dataGrid>
                </vbox>
            </tab>
        </tabSheet>
    </layout>
</view>