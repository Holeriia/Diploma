<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://requestApprovalListView.title"
      focusComponent="requestApprovalsDataGrid">
    <data>
        <collection id="requestApprovalsDc"
                    class="com.company.diploma.entity.RequestApproval">
            <fetchPlan extends="_base">
                <property name="request" fetchPlan="_instance_name"/>
                <property name="approver" fetchPlan="_instance_name"/>
            </fetchPlan>
            <loader id="requestApprovalsDl" readOnly="true">
                <query>
                    <![CDATA[select e from RequestApproval e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="requestApprovalsDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="requestApprovalsDataGrid.createAction"/>
            <button id="editButton" action="requestApprovalsDataGrid.editAction"/>
            <button id="removeButton" action="requestApprovalsDataGrid.removeAction"/>
            <simplePagination id="pagination" dataLoader="requestApprovalsDl"/>
        </hbox>
        <dataGrid id="requestApprovalsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="requestApprovalsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="request"/>
                <column property="approver"/>
                <column property="decision"/>
                <column property="actionDate"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
