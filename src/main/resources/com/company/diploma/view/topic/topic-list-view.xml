<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://topicListView.title"
      focusComponent="topicsDataGrid">
    <data>
        <collection id="topicsDc"
                    class="com.company.diploma.entity.Topic">
            <fetchPlan extends="_base">
                <property name="author" fetchPlan="_instance_name"/>
            </fetchPlan>
            <loader id="topicsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Topic e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="topicsDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="topicsDataGrid.createAction"/>
            <button id="editButton" action="topicsDataGrid.editAction"/>
            <button id="removeButton" action="topicsDataGrid.removeAction"/>
            <simplePagination id="pagination" dataLoader="topicsDl"/>
        </hbox>
        <dataGrid id="topicsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="topicsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="name"/>
                <column property="description"/>
                <column property="author"/>
                <column property="status"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
