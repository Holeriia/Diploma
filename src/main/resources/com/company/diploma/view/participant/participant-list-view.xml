<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://participantListView.title"
      focusComponent="participantsDataGrid">
    <data>
        <collection id="participantsDc"
                    class="com.company.diploma.entity.Participant">
            <fetchPlan>
                <property name="user" fetchPlan="_instance_name"/>
            </fetchPlan>
            <loader id="participantsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Participant e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="participantsDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="participantsDataGrid.createAction"/>
            <button id="editButton" action="participantsDataGrid.editAction"/>
            <button id="removeButton" action="participantsDataGrid.removeAction"/>
            <simplePagination id="pagination" dataLoader="participantsDl"/>
        </hbox>
        <dataGrid id="participantsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="participantsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="user"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
