<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://teacherListView.title"
      focusComponent="teachersDataGrid">
    <data>
        <collection id="teachersDc"
                    class="com.company.diploma.entity.Teacher">
            <fetchPlan extends="_base">
                <property name="user" fetchPlan="_instance_name"/>
                <property name="department" fetchPlan="_instance_name"/>
                <property name="degree" fetchPlan="_instance_name"/>
                <property name="position" fetchPlan="_instance_name"/>
            </fetchPlan>
            <loader id="teachersDl" readOnly="true">
                <query>
                    <![CDATA[select e from Teacher e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="teachersDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="teachersDataGrid.createAction"/>
            <button id="editButton" action="teachersDataGrid.editAction"/>
            <button id="removeButton" action="teachersDataGrid.removeAction"/>
            <simplePagination id="pagination" dataLoader="teachersDl"/>
        </hbox>
        <dataGrid id="teachersDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="teachersDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="user"/>
                <column property="department"/>
                <column property="degree"/>
                <column property="title"/>
                <column property="position"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
