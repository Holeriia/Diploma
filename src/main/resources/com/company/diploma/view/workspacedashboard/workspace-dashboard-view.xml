<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://workspaceDashboardView.title">

    <data>
        <collection id="requestsDc"
                    class="com.company.diploma.entity.Request">
            <fetchPlan extends="_base"/>
            <loader id="requestsDl">
                <query>
                    <![CDATA[select r from Request r
                     where r.initiator.user.id = :current_user_id]]>
                </query>
            </loader>
        </collection>

        <collection id="tasksDc"
                    class="io.jmix.bpm.entity.TaskData">
            <loader id="tasksDl"/>
        </collection>

        <collection id="assignmentsDc"
                    class="com.company.diploma.entity.Assignment">
            <fetchPlan extends="_base">
                <property name="mentor" fetchPlan="_base"/>
                <property name="mentee" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="assignmentsDl">
                <query>
                    <![CDATA[select e from Assignment e
                 where e.mentor.user.id = :current_user_id
                 or e.mentee.user.id = :current_user_id]]>
                </query>
            </loader>
        </collection>

        <collection id="topicsDc"
                    class="com.company.diploma.entity.Topic">
            <fetchPlan extends="_base">
                <property name="interests" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="topicsDl">
                <query>
                    <![CDATA[select e from Topic e
                 where e.author.user.id = :current_user_id]]>
                </query>
            </loader>
        </collection>

    </data>

    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>

    <layout>
        <tabSheet id="mainTabs" width="100%">
            <tab id="tasksTab" label="Входящие">
                <vbox>
                    <h3 text="Мои задачи"/>
                    <dataGrid id="tasksDataGrid"
                              width="100%"
                              minHeight="15em"
                              dataContainer="tasksDc">
                        <columns>
                            <column property="name" header="Задача"/>
                            <column property="createTime" header="Получена" autoWidth="true"/>
                        </columns>
                        <actions>
                            <!-- действие для открытия формы задачи -->
                            <action id="openTaskForm" type="list_edit"/>
                        </actions>
                    </dataGrid>
                </vbox>

            </tab>

            <tab id="requetsTab" label="Заявки">
                <vbox classNames="p-m">

                    <h3 text="Мои заявки"/>

                    <hbox classNames="buttons-panel">
                        <button action="requestsGrid.createAction" text="msg://com.company.diploma.view.workspace/com.company.diploma.create"/>
                        <button action="requestsGrid.editAction" text="msg://com.company.diploma.view.workspace/com.company.diploma.edit"/>
                        <button action="requestsGrid.removeAction" text="msg://com.company.diploma.view.workspace/com.company.diploma.delete"/>
                    </hbox>

                    <dataGrid id="requestsGrid"
                              dataContainer="requestsDc"
                              width="100%">

                        <actions>
                            <action id="createAction" type="list_create">
                                <properties>
                                    <property name="openMode" value="DIALOG"/>
                                    <property name="viewId" value="Request.create"/>
                                </properties>
                            </action>

                            <action id="editAction" type="list_edit"/>
                            <action id="removeAction" type="list_remove"/>
                        </actions>

                        <columns>
                            <column property="name"/>
                            <column property="status"/>
                        </columns>

                    </dataGrid>

                </vbox>
            </tab>
            <tab id="assignmentsTab" label="Назначения тем">
                <vbox classNames="p-m">
                    <h3 text="Мои назначения"/>
                    <dataGrid id="assignmentsGrid"
                              dataContainer="assignmentsDc"
                              width="100%">
                        <columns>
                            <column property="mentor" header="Ментор"/>
                            <column property="mentee" header="Менти"/>
                            <column key="topicColumn" header="Тема"/>
                            <column property="status"/>
                        </columns>
                    </dataGrid>


                    <h3 text="Мои темы"/>

                    <hbox classNames="buttons-panel">
                        <button action="topicsGrid.create" text="msg://com.company.diploma.view.workspace/com.company.diploma.create"/>
                        <button action="topicsGrid.edit" text="msg://com.company.diploma.view.workspace/com.company.diploma.edit"/>
                        <button action="topicsGrid.remove" text="msg://com.company.diploma.view.workspace/com.company.diploma.delete"/>
                    </hbox>

                    <dataGrid id="topicsGrid"
                              dataContainer="topicsDc"
                              width="100%">
                        <actions>
                            <action id="create" type="list_create">
                                <properties>
                                    <property name="openMode" value="DIALOG"/>
                                </properties>
                            </action>
                            <action id="edit" type="list_edit">
                                <properties>
                                    <property name="openMode" value="DIALOG"/>
                                </properties>
                            </action>
                            <action id="remove" type="list_remove"/>
                        </actions>
                        <columns>
                            <column property="name"/>
                            <column property="status"/>
                            <column key="interestsColumn" header="Интересы" width="20em"/>
                        </columns>
                    </dataGrid>
                </vbox>

            </tab>
        </tabSheet>
    </layout>
</view>