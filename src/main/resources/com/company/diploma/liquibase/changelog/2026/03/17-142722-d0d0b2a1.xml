<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="Diploma">
        <createTable tableName="INTEREST">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_INTEREST"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="DESCRIPTION" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="Diploma">
        <createTable tableName="STUDENT_INTEREST_LINK">
            <column name="INTEREST_ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_STUDENT_INTEREST_LINK"/>
            </column>
            <column name="STUDENT_ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_STUDENT_INTEREST_LINK"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="3" author="Diploma">
        <addForeignKeyConstraint baseColumnNames="INTEREST_ID" baseTableName="STUDENT_INTEREST_LINK"
                                 constraintName="FK_STUINT_ON_INTEREST" referencedColumnNames="ID"
                                 referencedTableName="INTEREST"/>
    </changeSet>
    <changeSet id="4" author="Diploma">
        <addForeignKeyConstraint baseColumnNames="STUDENT_ID" baseTableName="STUDENT_INTEREST_LINK"
                                 constraintName="FK_STUINT_ON_STUDENT" referencedColumnNames="ID"
                                 referencedTableName="STUDENT"/>
    </changeSet>
</databaseChangeLog>